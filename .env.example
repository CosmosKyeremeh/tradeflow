# Supabase project settings (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Postgres connection string used by Drizzle (Project Settings -> Database ->
# Connection string -> "Transaction pooler" is the safest default for
# serverless/edge environments like Vercel)
DATABASE_URL=postgresql://postgres.your-project-ref:[email protected]:6543/postgres

# Comma-separated emails allowed to manage the shared tariff schedule
# (src/app/dashboard/admin). This is shared reference data across every
# organization, so access is intentionally not tied to any org's role.
ADMIN_EMAILS=admin@example.com
